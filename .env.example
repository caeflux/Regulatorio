# ===========================================
# RegTelecom - Environment Variables
# ===========================================

# Database
DATABASE_URL=postgresql://regtelecom:regtelecom_dev_2026@localhost:5432/regtelecom
DB_PASSWORD=regtelecom_dev_2026

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# GOV.BR OAuth2
# Solicitar credenciais em: https://manual-roteiro-integracao-login-unico.servicos.gov.br/
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_REDIRECT_URI=http://localhost:3000/auth/callback/govbr
GOVBR_AUTH_URL=https://sso.staging.acesso.gov.br/authorize
GOVBR_TOKEN_URL=https://sso.staging.acesso.gov.br/token
GOVBR_USERINFO_URL=https://sso.staging.acesso.gov.br/userinfo

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# API
API_PORT=3001
API_HOST=0.0.0.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOVBR_CLIENT_ID=

# SendGrid (alertas por email)
# Criar conta em: https://sendgrid.com/ → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=alertas@regtelecom.com.br
SENDGRID_FROM_NAME=RegTelecom

# WhatsApp Business API (alertas)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# AWS S3 (documentos e CSVs)
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_DOCUMENTS=regtelecom-documents
S3_BUCKET_REPORTS=regtelecom-reports

# Integração ERPs
HUBSOFT_API_URL=
HUBSOFT_API_KEY=
IXCSOFT_API_URL=
IXCSOFT_API_TOKEN=
